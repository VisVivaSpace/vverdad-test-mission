# Lamberto sweep configuration — rendered by VVERDAD from mission constraints
# Phobos Sample Return: Earth-Mars outbound and Mars-Earth return scans
# Ephemeris: lamberto embeds DE440 (2000-2075), no external SPK needed.

sweeps:
  - name: "outbound_earth_mars"
    departure_body: "Earth"
    arrival_body: "Mars"
    departure_start: "{{ mission.constraints.launch_energy.launch_window_open | to_utc }}"
    departure_end: "{{ mission.constraints.launch_energy.launch_window_close | to_utc }}"
    departure_step_days: 1
    arrival_start: "2036-03-01T00:00:00 UTC"
    arrival_end: "2036-07-01T00:00:00 UTC"
    arrival_step_days: 1
    direction: prograde
    nrev: 0

  - name: "return_mars_earth"
    departure_body: "Mars"
    arrival_body: "Earth"
    departure_start: "{{ mission.constraints.earth_return.departure_window_open | to_utc }}"
    departure_end: "{{ mission.constraints.earth_return.departure_window_close | to_utc }}"
    departure_step_days: 1
    arrival_start: "2038-07-01T00:00:00 UTC"
    arrival_end: "2038-11-01T00:00:00 UTC"
    arrival_step_days: 1
    direction: prograde
    nrev: 0
