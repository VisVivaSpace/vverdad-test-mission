Analysis(
    id: "trajectory_scan",
    version: "2.0.0",
    description: Some("Earth-Mars-Earth porkchop scan using lamberto for Phobos Sample Return"),
    image: "ubuntu:latest",
    entrypoint: "apt-get update -qq && apt-get install -y -qq curl >/dev/null 2>&1 && curl -sL https://github.com/VisVivaSpace/lamberto/releases/latest/download/lamberto-x86_64-unknown-linux-gnu.tar.gz | tar xz && ./lamberto config.yaml -o .",
    inputs: [
        // Launch constraints (used by config.yaml.j2 template)
        Input(key: "mission.constraints.launch_energy.launch_window_open", required: true),
        Input(key: "mission.constraints.launch_energy.launch_window_close", required: true),
        // Earth return constraints
        Input(key: "mission.constraints.earth_return.departure_window_open", required: true),
        Input(key: "mission.constraints.earth_return.departure_window_close", required: true),
    ],
    outputs: [
        Output(key: "outbound_earth_mars.csv"),
        Output(key: "return_mars_earth.csv"),
        Output(key: "summary.yaml"),
    ],
    templates: [
        Template(source: "config.yaml.j2", destination: "config.yaml"),
    ],
    static_files: [],
    resources: Resources(
        cpu_cores: 2.0,
        memory_mb: 4096,
        timeout_seconds: 600,
    ),
)
